generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Tenant {
  id          String   @id @default(uuid())
  name        String
  logo        String?
  domain      String?  @unique
  status      String   @default("active")
  plan        String   @default("basic")
  maxUsers    Int      @default(100)
  maxApps     Int      @default(10)
  
  // 品牌设置
  brandSettings Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  adminTenants    AdminTenant[]
  currentAdmins   Admin[]
  users           User[]
  applications    Application[]
  roles           Role[]
  groups          UserGroup[]
  positions       Position[]
  webhooks        Webhook[]
  auditLogs       AuditLog[]
  socialIdentityProviders SocialIdentityProvider[]
  customDomains   CustomDomain[]
  messageTemplates MessageTemplate[]
  loginStyle      LoginStyle?

  @@map("tenants")
}

model Admin {
  id               String   @id @default(uuid())
  currentTenantId  String?
  username         String   @unique
  email            String   @unique
  phone            String?
  password         String
  status           String   @default("active")
  lastLoginAt      DateTime?
  passwordChangedAt DateTime @default(now())
  mfaEnabled       Boolean  @default(false)
  mfaSecret        String?
  mfaType          String?  // 'totp', 'sms', 'email'
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  currentTenant    Tenant?  @relation(fields: [currentTenantId], references: [id], onDelete: SetNull)
  tenants          AdminTenant[]
  roles            AdminRole[]
  passwordHistory  PasswordHistory[]
  mfaTokens        MfaToken[]
  
  @@index([currentTenantId])
  @@map("admins")
}

model AdminTenant {
  id        String   @id @default(uuid())
  adminId   String
  tenantId  String
  role      String   @default("owner")
  createdAt DateTime @default(now())
  
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@unique([adminId, tenantId])
  @@index([adminId])
  @@index([tenantId])
  @@map("admin_tenants")
}

model AdminRole {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  permissions Json
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  admins      Admin[]
  
  @@index([tenantId])
  @@map("admin_roles")
}

model User {
  id               String   @id @default(uuid())
  tenantId         String
  username         String
  email            String
  phone            String?
  password         String?
  name             String
  avatar           String?
  status           String   @default("active")
  emailVerified    Boolean  @default(false)
  phoneVerified    Boolean  @default(false)
  department       String?
  position         String?
  customAttributes Json?
  lastLoginAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groups           UserGroup[] @relation("UserToGroup")
  groupAdmins      UserGroup[] @relation("GroupAdmin")
  roles            Role[]   @relation("UserToRole")
  devices          Device[]
  socialAccounts   SocialAccount[]
  
  @@unique([tenantId, username])
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model UserGroup {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  type        String   @default("team")
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      UserGroup?  @relation("GroupHierarchy", fields: [parentId], references: [id])
  children    UserGroup[]  @relation("GroupHierarchy")
  members     User[]    @relation("UserToGroup")
  admins      User[]    @relation("GroupAdmin")
  
  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("user_groups")
}

model Position {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  code        String
  description String?
  departmentId String?
  level       Int      @default(1)
  sequence    String?
  userCount   Int      @default(0)
  maxCount    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("positions")
}

model Application {
  id                   String   @id @default(uuid())
  tenantId             String
  name                 String
  logo                 String?
  description          String?
  type                 String   @default("web")
  clientId             String   @unique
  clientSecret         String
  redirectUris         Json
  allowedGrantTypes    Json
  accessTokenLifetime  Int      @default(3600)
  refreshTokenLifetime Int      @default(2592000)
  status               String   @default("active")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
  @@map("applications")
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  code        String
  description String?
  type        String   @default("custom")
  permissions Json
  dataScope   String   @default("self")
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      Role?    @relation("RoleHierarchy", fields: [parentId], references: [id])
  children    Role[]   @relation("RoleHierarchy")
  users       User[]   @relation("UserToRole")
  
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  tenantId    String
  code        String
  name        String
  description String?
  type        String   @default("operation")
  parentId    String?
  resource    String
  action      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  parent      Permission?  @relation("PermissionHierarchy", fields: [parentId], references: [id])
  children    Permission[] @relation("PermissionHierarchy")
  
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("permissions")
}

model SocialAccount {
  id           String   @id @default(uuid())
  userId       String
  provider     String
  providerId   String
  accessToken  String?
  refreshToken String?
  profile      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerId])
  @@index([userId])
  @@map("social_accounts")
}

model Device {
  id           String   @id @default(uuid())
  userId       String
  deviceType   String
  os           String
  browser      String
  fingerprint  String
  ipAddress    String
  location     String?
  isTrusted    Boolean  @default(false)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("devices")
}

model Webhook {
  id            String   @id @default(uuid())
  tenantId      String
  name          String
  url           String
  events        Json
  headers       Json?
  secret        String
  status        String   @default("active")
  maxRetries    Int      @default(3)
  retryInterval Int      @default(5000)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
  @@map("webhooks")
}

model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String?
  username     String?
  type         String
  action       String
  resource     String
  resourceId   String?
  method       String?
  ip           String
  userAgent    String?
  location     String?
  status       String
  errorMessage String?
  changes      Json?
  createdAt    DateTime @default(now())
  
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId, createdAt])
  @@index([userId])
  @@index([type])
  @@map("audit_logs")
}

model SocialIdentityProvider {
  id                    String   @id @default(uuid())
  tenantId              String
  name                  String
  type                  String
  clientId              String
  clientSecret          String
  authorizationEndpoint String
  tokenEndpoint         String
  userInfoEndpoint      String
  scope                 Json
  attributeMapping      Json?
  status                String   @default("active")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
  @@map("social_identity_providers")
}

model SystemConfig {
  id                    String   @id @default(uuid())
  tenantId              String
  category              String
  key                   String
  value                 Json
  description           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@unique([tenantId, category, key])
  @@index([tenantId])
  @@map("system_configs")
}

model PasswordHistory {
  id        String   @id @default(uuid())
  userId    String
  password  String
  createdAt DateTime @default(now())
  
  admin     Admin    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("password_histories")
}

model MfaToken {
  id        String   @id @default(uuid())
  userId    String
  token     String
  type      String   // 'totp', 'sms', 'email'
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  admin     Admin    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([token])
  @@map("mfa_tokens")
}

model SecurityPolicy {
  id                      String   @id @default(uuid())
  tenantId                String   @unique
  passwordMinLength       Int      @default(8)
  passwordRequireUpper    Boolean  @default(true)
  passwordRequireLower    Boolean  @default(true)
  passwordRequireNumber   Boolean  @default(true)
  passwordRequireSpecial  Boolean  @default(true)
  passwordMaxAge          Int      @default(90)
  passwordHistoryCount    Int      @default(5)
  mfaRequired             Boolean  @default(false)
  mfaType                 String   @default("totp")
  sessionTimeout          Int      @default(7200)
  loginAttemptsLimit      Int      @default(5)
  lockoutDuration         Int      @default(1800)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  
  @@index([tenantId])
  @@map("security_policies")
}

model CustomDomain {
  id              String   @id @default(uuid())
  tenantId        String
  domain          String   @unique
  status          String   @default("pending") // pending, verifying, verified, failed
  verificationMethod String @default("dns") // dns, file
  verificationToken String?
  verifiedAt      DateTime?
  sslStatus       String   @default("none") // none, pending, active, expired
  sslCertificate  String?
  sslPrivateKey   String?
  sslExpiresAt    DateTime?
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
  @@index([domain])
  @@map("custom_domains")
}

model MessageTemplate {
  id          String   @id @default(uuid())
  tenantId    String
  type        String   // email, sms
  code        String   // verification_code, password_reset, welcome, etc.
  name        String
  subject     String?  // for email
  content     String
  variables   Json?    // available variables
  isDefault   Boolean  @default(false)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@unique([tenantId, type, code])
  @@index([tenantId])
  @@map("message_templates")
}

model LoginStyle {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  logo            String?
  logoDark        String?
  backgroundImage String?
  backgroundColor String   @default("#f5f7fa")
  primaryColor    String   @default("#0369A1")
  title           String   @default("Easy1Auth")
  subtitle        String   @default("企业级身份管理平台")
  customCSS       String?
  loginMethods    Json?    // enabled login methods
  socialProviders Json?    // enabled social providers
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@map("login_styles")
}
